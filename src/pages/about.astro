---
import BaseLayout from '../layouts/BaseLayout.astro';
import PortableText from '../components/PortableText.astro';
import { getAbout, urlFor } from '../lib/sanity';

const about = await getAbout();

const description =
  'Colleen McCann — technical leader, researcher, speaker, and developer of Strategy Language, a system for influential communication.';

const jsonLd = about && {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: about.name,
  description,
  image: urlFor(about.headshot).width(600).url(),
  jobTitle: 'Technical leader and researcher',
  url: 'https://colleenmccann.net/about',
};
---

<BaseLayout title="About" description={description} active="about" jsonLd={jsonLd}>
  <section class="wrap about-page">
    <h1>About</h1>
    <p class="text-secondary subhead">The person behind the research.</p>

    {about && (
      <div class="about-body">
        <img
          class="headshot"
          src={urlFor(about.headshot).width(400).height(400).fit('crop').url()}
          alt={about.headshot.alt}
          width="200"
          height="200"
        />
        <div class="bio">
          <PortableText value={about.bio} />
        </div>
      </div>
    )}
  </section>
</BaseLayout>

<style>
  .about-page {
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
  }

  .subhead {
    font-size: 1.1rem;
    margin-top: -0.5rem;
  }

  .about-body {
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    margin-top: var(--space-4);
    flex-wrap: wrap;
  }

  .headshot {
    border-radius: 8px;
    object-fit: cover;
    flex-shrink: 0;
  }

  .bio {
    flex: 1;
    min-width: 280px;
  }
</style>
