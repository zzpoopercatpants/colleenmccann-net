---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getContact } from '../lib/sanity';

const contact = await getContact();
const description = 'Get in touch with Colleen McCann.';
---

<BaseLayout title="Contact" description={description} active="contact">
  <section class="wrap contact-page">
    <h1>Contact</h1>
    {contact && (
      <>
        <p class="text-secondary subhead">{contact.blurb}</p>
        <ul class="contact-links">
          {contact.email && (
            <li><a class="link" href={`mailto:${contact.email}`}>{contact.email}</a></li>
          )}
          <li>
            <a class="link link-external" href={contact.linkedinUrl} target="_blank" rel="noopener">
              LinkedIn
            </a>
          </li>
        </ul>
      </>
    )}
  </section>
</BaseLayout>

<style>
  .contact-page {
    padding-top: var(--space-4);
    padding-bottom: var(--space-5);
  }

  .subhead {
    font-size: 1.1rem;
    margin-top: -0.5rem;
    max-width: 480px;
  }

  .contact-links {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 1.05rem;
  }
</style>
