---
import { PortableText as PT } from 'astro-portabletext';
import SanityImage from './portabletext/SanityImage.astro';
import CalloutBox from './portabletext/CalloutBox.astro';
import IconTextCard from './portabletext/IconTextCard.astro';
import Table from './portabletext/Table.astro';

interface Props {
  value: any[];
}
const { value } = Astro.props;

const components = {
  type: {
    image: SanityImage,
    calloutBox: CalloutBox,
    iconTextCard: IconTextCard,
    richTableBlock: Table,
  },
};
---

<div class="prose">
  <PT value={value || []} components={components} />
</div>

<style>
  .prose {
    color: var(--color-text-body);
    font-size: 1.05rem;
  }

  .prose :global(h2),
  .prose :global(h3) {
    margin-top: var(--space-4);
  }

  .prose :global(p) {
    margin: 0 0 var(--space-3);
  }

  .prose :global(a) {
    color: var(--color-text-secondary);
  }

  .prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
    margin: var(--space-3) 0;
  }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-border);
    padding-left: var(--space-3);
    color: var(--color-text-muted);
    margin: var(--space-3) 0;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-3);
    padding-left: 1.25rem;
  }
</style>
